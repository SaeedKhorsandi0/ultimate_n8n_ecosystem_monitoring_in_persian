        "jsCode": "// فرض بر این است که ورودی از نود AI به نام 'text' وارد می‌شود\nconst input = $input.first().json.text;\n\n// استفاده از Regex برای استخراج محتوا بین تگ‌های تایتل و دسکریپشن\nconst titleMatch = input.match(/Title:\\s*(.*)/i);\nconst descriptionMatch = input.match(/Description:\\s*([\\s\\S]*)/i);\n\nreturn [\n  {\n    json: {\n      translatedTitle: titleMatch ? titleMatch[1].trim() : \"بدون عنوان\",\n      translatedDescription: descriptionMatch ? descriptionMatch[1].trim() : \"بدون توضیحات\"\n    }\n  }\n];"
      },
