      "parameters": {
        "jsCode": "/*\n * n8n Code Node: Split YouTube Search Results\n *\n * این کد ورودی نود HTTP Request را می‌گیرد و آرایه 'items' (نتایج جستجو)\n * را به آیتم‌های جداگانه در n8n تبدیل می‌کند.\n *\n * ساختار ورودی مورد انتظار (بر اساس نمونه شما):\n * items = [\n * {\n * json: [\n * {\n * \"kind\": \"youtube#searchListResponse\",\n * \"items\": [\n * { \"id\": ..., \"snippet\": ... },\n * { \"id\": ..., \"snippet\": ... },\n * ...\n * ]\n * }\n * ]\n * }\n * ]\n */\n\nconst newItems = [];\n\n// پیمایش تمام آیتم‌های ورودی n8n\n// (معمولاً نود HTTP Request فقط یک آیتم خروجی می‌دهد)\nfor (const item of items) {\n  try {\n    // 1. داده‌های JSON را از ورودی بگیرید\n    const inputJson = item.json;\n    let youtubeResponse;\n\n    // 2. بررسی کنید که آیا 'inputJson' آرایه است یا آبجکت\n    // این کد حالا هر دو حالت را مدیریت می‌کند:\n    // حالت ۱: item.json یک آرایه است (مثل نمونه شما) -> [ { ... } ]\n    // حالت ۲: item.json خود آبجکت است (بسیار رایج) -> { ... }\n    if (Array.isArray(inputJson) && inputJson.length > 0) {\n      // اگر آرایه بود (مثل نمونه‌ای که فرستادید)، عنصر اول را بردارید\n      youtubeResponse = inputJson[0];\n    } else if (typeof inputJson === 'object' && inputJson !== null && !Array.isArray(inputJson)) {\n      // اگر یک آبجکت بود (که این هم رایج است)، مستقیماً از آن استفاده کنید\n      youtubeResponse = inputJson;\n    } else {\n      // اگر ساختار ناشناخته بود، لاگ بزن و برو\n      console.warn(\"Input JSON is not in a recognized format (array or object):\", inputJson);\n      continue; // برو سراغ آیتم بعدی n8n\n    }\n\n\n    // 3. حالا آرایه 'items' را از داخل آن آبجکت استخراج می‌کنیم.\n    const videoList = youtubeResponse.items;\n\n    // 4. بررسی می‌کنیم که 'videoList' واقعاً یک آرایه باشد\n    if (Array.isArray(videoList)) {\n      \n      // 5. به ازای هر ویدئو/کانال در 'videoList'، یک آیتم جدید n8n می‌سازیم\n      for (const video of videoList) {\n        \n        // 6. آیتم جدید را به لیست خروجی اضافه می‌کنیم.\n        // آبجکت کامل ویدئو در 'json' آیتم جدید قرار می‌گیرد.\n        newItems.push({\n          json: video\n        });\n      }\n    } else {\n      // اگر ساختار داده مورد انتظار نبود، یک هشدار در لاگ n8n ثبت کن\n      console.warn(\"Could not find 'items' array in youtubeResponse\", youtubeResponse);\n    }\n  } catch (error) {\n    // در صورت بروز خطا (مثلاً اگر 'item.json[0]' وجود نداشته باشد)\n    // خطا را در لاگ n8n ثبت کن\n    console.error(\"Error processing item. Make sure input data matches expected structure.\", error.message, item);\n  }\n}\n\n// 6. لیست جدید آیتم‌ها را برمی‌گردانیم.\n// n8n به طور خودکار این آرایه را به آیتم‌های جداگانه برای نود بعدی \"split\" می‌کند.\nreturn newItems;"
      },
